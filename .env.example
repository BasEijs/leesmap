# --- De Correspondent access (you must be a paying member) ---

# Your personal RSS feed URL (all publications). Get it from
# https://decorrespondent.nl/rss while logged in — copy the "alle publicaties" link.
DC_RSS_URL=https://decorrespondent.nl/rss/...your-personal-feed...

# --- Login (preferred) ---
# Your De Correspondent email + password. The app logs in for you, caches the
# session on the /data volume, and re-logs-in automatically when it expires — no
# more hand-feeding cookies. Keep these secret; never commit your real .env.
DC_EMAIL=you@example.com
DC_PASSWORD=your_password

# --- Manual cookie (fallback) ---
# Optional. If set, it OVERRIDES the email login above and is used as-is (the old
# behaviour). Leave blank to use DC_EMAIL/DC_PASSWORD. To get it: in a browser on
# decorrespondent.nl, DevTools > Network > any request > Request Headers > copy
# the whole "Cookie:" value. A hand-fed cookie is NOT auto-refreshed.
DC_COOKIE=

# --- Reader ---
# CrossPoint on its own hotspot answers at 192.168.4.1 (or crosspoint.local).
# If the reader joined your home WiFi, use the IP your router gave it.
X4_IP=192.168.4.1

# --- Optional: protect the web UI with HTTP basic auth ---
# Leave blank if it's already private (e.g. behind Tailscale).
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# --- Optional: admin password for settings + send/publish ---
# Narrower than BASIC_AUTH_*: gates the "instellingen" drawer and the "Extra
# opties" actions (Verstuur naar X4 / Publiceer naar OPDS), while browsing and
# Download .epub stay open. Handy if you share the app (e.g. with family) and
# want to stop them from reconfiguring it or triggering a send by accident.
# Leave blank to disable the gate entirely.
ADMIN_PASSWORD=

# --- Optional ---
# PORT=8080
# USER_AGENT=
